---
// Shared brand badge: navy rounded square + brass keyline + white
// horse-and-rider silhouette. Keep in sync with public/favicon.svg.
import horseRider from "../assets/photos/logo-horse-rider.png";

interface Props {
  class?: string;
  bg?: string;
}
const { class: className = "h-10 w-10", bg = "#1C2A44" } = Astro.props;
---

<span class:list={["relative inline-block", className]} aria-hidden="true">
  <span class="absolute inset-0 rounded-[22%]" style={`background:${bg}`}></span>
  <span class="absolute inset-[7.4%] rounded-[17%] border border-brass/60"></span>
  <img
    src={horseRider.src}
    alt=""
    class="absolute inset-0 h-full w-full object-contain p-[16%]"
  />
</span>
