---
import { site, withBase } from "../data/site";

interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  showMessageButton?: boolean;
}

const {
  eyebrow = "Visit Avastar",
  heading = "Come see the farm for yourself.",
  body = "The best way to experience Avastar is in person. Call Jenn to talk boarding, training, or lessons, or to schedule a time to visit.",
  showMessageButton = true,
} = Astro.props;
---

<section class="bg-navy text-cream">
  <div class="mx-auto max-w-4xl px-5 sm:px-8 py-16 md:py-20 text-center">
    <p class="eyebrow eyebrow-on-dark eyebrow--rule justify-center">
      {eyebrow}
    </p>
    <h2 class="mt-5 text-3xl sm:text-4xl md:text-[2.75rem] text-cream">
      {heading}
    </h2>
    <p class="mx-auto mt-5 max-w-2xl text-base sm:text-lg leading-relaxed text-cream/80">
      {body}
    </p>
    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href={site.phone.href} class="btn btn-brass w-full sm:w-auto">
        <svg
          viewBox="0 0 24 24"
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        Call {site.phone.display}
      </a>
      {
        showMessageButton && (
          <a href={withBase("/contact")} class="btn btn-ghost w-full sm:w-auto">
            Send a message
          </a>
        )
      }
    </div>
  </div>
</section>
