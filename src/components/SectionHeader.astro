---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: "left" | "center";
  tone?: "light" | "dark";
  class?: string;
}

const {
  eyebrow,
  title,
  intro,
  align = "left",
  tone = "light",
  class: className = "",
} = Astro.props;

const isCenter = align === "center";
const isDark = tone === "dark";
---

<div
  class:list={[
    isCenter ? "text-center" : "text-left",
    isCenter ? "mx-auto max-w-2xl" : "",
    className,
  ]}
>
  {
    eyebrow && (
      <p
        class:list={[
          "eyebrow eyebrow--rule",
          isDark && "eyebrow-on-dark",
          isCenter && "justify-center",
        ]}
      >
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      "text-3xl sm:text-4xl md:text-[2.6rem]",
      eyebrow && "mt-4",
      isDark ? "text-cream" : "text-navy",
    ]}
  >
    {title}
  </h2>
  {
    intro && (
      <p
        class:list={[
          "mt-5 text-lg leading-relaxed",
          isCenter && "mx-auto",
          isDark ? "text-cream/80" : "text-ink/80",
          "max-w-2xl",
        ]}
      >
        {intro}
      </p>
    )
  }
</div>
