---
import { site, nav, withBase } from "../data/site";
import BrandMark from "./BrandMark.astro";

const path = Astro.url.pathname;
const isActive = (href: string) => {
  const target = withBase(href);
  return href === "/"
    ? path === target || path === target.replace(/\/$/, "")
    : path.startsWith(target);
};
---

<header
  class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-line"
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex h-20 items-center justify-between gap-4">
      <!-- Wordmark -->
      <a
        href={withBase("/")}
        class="group flex items-center gap-3"
        aria-label={`${site.name} home`}
      >
        <BrandMark class="h-10 w-10 shrink-0" />
        <span class="flex flex-col leading-none">
          <span
            class="font-display text-xl font-semibold tracking-tight text-navy"
            >Avastar</span
          >
          <span
            class="mt-0.5 text-[0.62rem] font-semibold uppercase tracking-[0.28em] text-brass-deep"
            >Dressage</span
          >
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
        {
          nav.map((item) => (
            <a
              href={withBase(item.href)}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "relative px-3.5 py-2 text-sm font-medium transition-colors rounded-md",
                isActive(item.href)
                  ? "text-navy"
                  : "text-ink/75 hover:text-navy",
              ]}
            >
              {item.label}
              <span
                class:list={[
                  "pointer-events-none absolute inset-x-3.5 -bottom-0.5 h-px origin-left bg-brass transition-transform duration-200",
                  isActive(item.href) ? "scale-x-100" : "scale-x-0",
                ]}
              />
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2">
        <!-- Phone pill (desktop) -->
        <a
          href={site.phone.href}
          class="hidden sm:inline-flex btn btn-navy !px-4 !py-2 !text-sm"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          {site.phone.display}
        </a>

        <!-- Mobile hamburger -->
        <button
          id="nav-toggle"
          type="button"
          class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-md text-navy"
          aria-label="Open menu"
          aria-controls="mobile-nav"
          aria-expanded="false"
        >
          <svg
            id="nav-icon-open"
            viewBox="0 0 24 24"
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg
            id="nav-icon-close"
            viewBox="0 0 24 24"
            class="hidden h-6 w-6"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <nav
    id="mobile-nav"
    class="lg:hidden hidden border-t border-line bg-cream"
    aria-label="Mobile"
  >
    <ul class="mx-auto max-w-6xl px-5 py-3 sm:px-8">
      {
        nav.map((item) => (
          <li>
            <a
              href={withBase(item.href)}
              data-nav-link
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "block rounded-md px-3 py-3 text-base font-medium transition-colors",
                isActive(item.href)
                  ? "text-navy bg-oat"
                  : "text-ink/80 hover:text-navy hover:bg-oat/60",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2 pb-1">
        <a href={site.phone.href} data-nav-link class="btn btn-navy w-full">
          Call {site.phone.display}
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  const iconOpen = document.getElementById("nav-icon-open");
  const iconClose = document.getElementById("nav-icon-close");

  function setOpen(open: boolean) {
    if (!toggle || !panel || !iconOpen || !iconClose) return;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    panel.classList.toggle("hidden", !open);
    iconOpen.classList.toggle("hidden", open);
    iconClose.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    setOpen(!open);
  });

  // Close when a link is tapped
  panel?.querySelectorAll("[data-nav-link]").forEach((link) => {
    link.addEventListener("click", () => setOpen(false));
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });

  // Close when tapping/clicking anywhere outside the open menu
  document.addEventListener("click", (e) => {
    if (toggle?.getAttribute("aria-expanded") !== "true") return;
    const target = e.target as Node;
    if (panel?.contains(target) || toggle?.contains(target)) return;
    setOpen(false);
  });
</script>
