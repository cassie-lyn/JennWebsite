---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  eyebrow?: string;
  title: string;
  imageSide?: "left" | "right";
  bg?: "cream" | "oat";
  position?: string;
  aspect?: string;
  imgWidth?: number;
  id?: string;
}

const {
  image,
  alt,
  eyebrow,
  title,
  imageSide = "right",
  bg = "cream",
  position = "center",
  aspect = "aspect-[4/5]",
  imgWidth = 1040,
  id,
} = Astro.props;
---

<section id={id} class:list={[bg === "oat" ? "bg-oat" : "bg-cream", id && "scroll-mt-24"]}>
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-18 md:py-24">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class={imageSide === "left" ? "lg:order-2" : ""}>
        {eyebrow && <p class="eyebrow eyebrow--rule">{eyebrow}</p>}
        <h2 class:list={["text-3xl sm:text-4xl text-navy", eyebrow && "mt-4"]}>
          {title}
        </h2>
        <div class="prose-body mt-6 text-ink/85">
          <slot />
        </div>
      </div>

      <div class={imageSide === "left" ? "lg:order-1" : ""}>
        <div class:list={["photo-frame", aspect]}>
          <Image
            src={image}
            alt={alt}
            width={imgWidth}
            class="h-full w-full object-cover"
            style={`object-position: ${position};`}
          />
        </div>
      </div>
    </div>
  </div>
</section>
