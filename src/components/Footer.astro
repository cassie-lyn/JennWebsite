---
import { site, nav, withBase } from "../data/site";
import BrandMark from "./BrandMark.astro";
const year = new Date().getFullYear();
const { address } = site;
---

<footer class="bg-navy text-cream/85">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-14 md:py-16">
    <div class="grid gap-10 md:grid-cols-3 md:gap-12">
      <!-- Wordmark + one-liner -->
      <div>
        <div class="flex items-center gap-3">
          <BrandMark class="h-9 w-9" bg="#14203A" />
          <span class="flex flex-col leading-none">
            <span class="font-display text-lg font-semibold text-cream"
              >Avastar</span
            >
            <span
              class="mt-0.5 text-[0.6rem] font-semibold uppercase tracking-[0.28em] text-brass"
              >Dressage</span
            >
          </span>
        </div>
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-cream/70">
          Full-service dressage training and boarding, built on classical
          foundations.
        </p>
        <p
          class="mt-4 text-xs font-semibold uppercase tracking-[0.18em] text-brass"
        >
          At Lepore Farm · Est. {site.established}
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h2
          class="text-xs font-semibold uppercase tracking-[0.2em] text-cream/55"
        >
          Explore
        </h2>
        <ul class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2.5 text-sm">
          {
            nav.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="text-cream/80 transition-colors hover:text-brass"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={site.facebook}
              target="_blank"
              rel="noopener noreferrer"
              class="text-cream/80 transition-colors hover:text-brass"
            >
              Facebook
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h2
          class="text-xs font-semibold uppercase tracking-[0.2em] text-cream/55"
        >
          Visit &amp; Contact
        </h2>
        <address class="mt-4 space-y-3 text-sm not-italic leading-relaxed">
          <p class="text-cream/75">
            {address.line1}<br />
            {address.line2}<br />
            {address.city}, {address.state} {address.zip}
          </p>
          <p>
            <a
              href={site.phone.href}
              class="font-medium text-cream transition-colors hover:text-brass"
            >
              {site.phone.display}
            </a>
          </p>
          <p>
            <a
              href={`mailto:${site.email}`}
              class="text-cream/80 transition-colors hover:text-brass break-all"
            >
              {site.email}
            </a>
          </p>
        </address>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-cream/15 pt-6 text-xs text-cream/55 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>Lincoln, Rhode Island · Dressage training &amp; boarding</p>
    </div>
  </div>
</footer>
