---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site, withBase } from "../data/site";

import heroImg from "../assets/photos/jenn-riding-hero.jpg";
import barnAisle from "../assets/photos/barn-aisle.jpg";
import sunriseBand from "../assets/photos/outdoor-arena-sunrise.jpg";
import jennPortrait from "../assets/photos/jenn-schooling.jpg";
import breePortrait from "../assets/photos/bree-riding.jpg";
import tonka from "../assets/photos/tonka.jpg";
import babyCat from "../assets/photos/baby-cat.jpg";

const features = [
  {
    title: "Full-Care Board",
    body:
      "European-style stalls, private turnout, hay four times a day, and genuinely individualized care. Jenn and Bree treat every horse like their own.",
    href: "/boarding",
    cta: "Explore boarding",
    icon: "home",
  },
  {
    title: "Training & Lessons",
    body:
      "Classical dressage training with a calm, patient coach who meets horse and rider where they are, then takes them further.",
    href: "/training",
    cta: "See training",
    icon: "ribbon",
  },
  {
    title: "Built for Dressage",
    body:
      "GGT footing in a warm indoor, a regulation outdoor dressage arena with judge's booth, and mowed paths for hacking out.",
    href: "/facility",
    cta: "Tour the facility",
    icon: "arena",
  },
];

const stats = [
  { value: "Est. 2008", label: "Avastar founded at Lepore Farm" },
  { value: "13-stall", label: "Main barn" },
  { value: "Regulation", label: "Outdoor dressage arena" },
  { value: "GGT footing", label: "Warm indoor arena" },
];

// Testimonials — add more entries here as they come in.
const testimonials = [
  {
    quote:
      "Jenn and her team treat your horse like their own. That's what sets Avastar apart. When I travel for work I never worry, because I know my horse is in good hands.",
    name: "Cassie G.",
    role: "Avastar boarder",
  },
];

const crew = [
  {
    name: "Jenn",
    role: "Trainer & Owner",
    img: jennPortrait,
    alt: "Jennifer Czechowski, trainer and owner of Avastar Dressage",
    position: "center 30%",
  },
  {
    name: "Bree",
    role: "Barn Manager",
    img: breePortrait,
    alt: "Briana “Bree” Dolbec, barn manager, riding a dappled grey horse",
    position: "center 25%",
  },
  {
    name: "Tonka",
    role: "Chief of Security",
    img: tonka,
    alt: "Tonka, Jenn's English bulldog, lying contentedly in the barn",
    position: "center",
  },
  {
    name: "Baby Cat",
    role: "Barn Cat in Chief",
    img: babyCat,
    alt: "Baby Cat, the fluffy light-grey resident barn cat, on the barn mats",
    position: "center 30%",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  name: site.name,
  description:
    "Full-service dressage training and boarding at Lepore Farm in Lincoln, Rhode Island, with USDF bronze and silver medalist Jennifer Czechowski.",
  url: site.url,
  telephone: site.phone.display,
  email: site.email,
  foundingDate: "2008",
  address: {
    "@type": "PostalAddress",
    streetAddress: "545 Angell Rd",
    addressLocality: "Lincoln",
    addressRegion: "RI",
    postalCode: "02865",
    addressCountry: "US",
  },
  areaServed: ["Rhode Island", "Southeastern Massachusetts"],
  sameAs: [site.facebook],
};

const description =
  "Avastar Dressage offers full-care horse boarding and classical dressage training in Lincoln, Rhode Island, with USDF bronze and silver medalist Jennifer Czechowski.";
---

<Layout title={site.name} description={description}>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- ============================ HERO ============================ -->
  <section class="overflow-hidden bg-gradient-to-b from-oat to-cream">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 pt-14 pb-16 md:pt-20 md:pb-24">
      <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-12">
        <div class="lg:col-span-6">
          <p class="eyebrow eyebrow--rule">
            {site.location}
          </p>
          <h1
            class="mt-5 text-4xl font-medium text-navy sm:text-5xl lg:text-[3.4rem] lg:leading-[1.1]"
          >
            Classical dressage training in a barn that feels like home
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink/80 sm:text-xl">
            Full board and training at Lepore Farm with USDF bronze and silver
            medalist Jennifer Czechowski.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a href={withBase("/contact")} class="btn btn-brass">Schedule a Visit</a>
            <a href={withBase("/boarding")} class="btn btn-outline">Explore Boarding</a>
          </div>
        </div>

        <div class="relative lg:col-span-6">
          <div class="photo-frame aspect-[4/3]">
            <Image
              src={heroImg}
              alt="Jennifer Czechowski riding a chestnut horse in a powerful extended trot, in a navy show coat"
              widths={[640, 960, 1280, 1600]}
              sizes="(min-width: 1024px) 48vw, 92vw"
              loading="eager"
              fetchpriority="high"
              class="h-full w-full object-cover object-[center_35%]"
            />
          </div>
          <div
            class="pointer-events-none absolute -bottom-4 -right-4 hidden h-28 w-28 rounded-2xl border border-brass/40 sm:block"
            aria-hidden="true"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ WELCOME ============================ -->
  <section class="bg-oat">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 md:py-28">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div class="lg:order-2">
          <p class="eyebrow eyebrow--rule">Welcome to Avastar</p>
          <h2 class="mt-4 text-3xl sm:text-4xl md:text-[2.6rem] text-navy">
            A dressage home in Lincoln, Rhode Island
          </h2>
          <div class="prose-body mt-6 text-lg text-ink/85">
            <p>
              Avastar Dressage is a full-service dressage facility at Lepore
              Farm, a beautiful equestrian property in Lincoln, Rhode Island.
              Since 2008, trainer Jenn Czechowski has helped riders build real
              partnerships with their horses, starting from a solid foundation
              of classical basics and building up to the top of the levels.
            </p>
            <p>
              Whether you have your eye on the show ring or simply want a more
              harmonious ride, Avastar can help you get there. And you'll do it
              surrounded by supportive, down-to-earth people who want to see
              you succeed.
            </p>
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={withBase("/about#jenn")} class="btn btn-outline">Meet Jenn</a>
            <a href={withBase("/training")} class="btn btn-outline">Training with Jenn</a>
          </div>
        </div>

        <div class="relative lg:order-1">
          <div class="photo-frame aspect-[4/5] lg:aspect-[5/6]">
            <Image
              src={barnAisle}
              alt="The Avastar barn aisle: European stall fronts with brass finials over a clean, rubber-matted aisle"
              widths={[480, 720, 960]}
              sizes="(min-width: 1024px) 40vw, 90vw"
              class="h-full w-full object-cover"
            />
          </div>
          <div
            class="pointer-events-none absolute -bottom-4 -left-4 hidden h-24 w-24 rounded-2xl border border-brass/40 sm:block"
            aria-hidden="true"
          >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ FEATURES ============================ -->
  <section class="bg-cream">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 md:py-24">
      <div class="max-w-2xl">
        <p class="eyebrow eyebrow--rule">What we offer</p>
        <h2 class="mt-4 text-3xl sm:text-4xl text-navy">
          Everything a serious dressage rider needs, all in one place
        </h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          features.map((f) => (
            <a
              href={withBase(f.href)}
              class="group flex flex-col rounded-2xl border border-line bg-white p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-brass/40 hover:shadow-xl"
            >
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-navy/5 text-brass-deep ring-1 ring-brass/20">
                {f.icon === "home" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 10.5 12 3l9 7.5" />
                    <path d="M5 9.5V21h14V9.5" />
                    <path d="M9 21v-6h6v6" />
                  </svg>
                )}
                {f.icon === "ribbon" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="9" r="6" />
                    <path d="M9 14.5 7 22l5-3 5 3-2-7.5" />
                  </svg>
                )}
                {f.icon === "arena" && (
                  <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="6" width="18" height="12" rx="2" />
                    <path d="M3 12h18" />
                    <path d="M12 6v12" />
                  </svg>
                )}
              </span>
              <h3 class="mt-5 text-xl font-semibold text-navy">{f.title}</h3>
              <p class="mt-3 flex-1 leading-relaxed text-ink/75">{f.body}</p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brass-deep">
                {f.cta}
                <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================= FULL-WIDTH IMAGE BAND ======================= -->
  <section class="relative isolate overflow-hidden bg-navy">
    <Image
      src={sunriseBand}
      alt="A pink sunrise over the outdoor dressage arena at Lepore Farm, with Adirondack chairs on the patio"
      widths={[640, 960, 1280]}
      sizes="100vw"
      loading="lazy"
      class="absolute inset-0 h-full w-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-navy/35"></div>
    <div
      class="relative mx-auto flex min-h-[340px] max-w-6xl items-end px-5 py-10 sm:px-8 md:min-h-[420px]"
    >
      <div>
        <p class="eyebrow eyebrow-on-dark text-sm font-bold drop-shadow-sm">
          Golden hour
        </p>
        <p
          class="mt-2 font-display text-3xl text-cream drop-shadow-sm sm:text-4xl md:text-5xl"
        >
          Mornings at Lepore Farm
        </p>
      </div>
    </div>
  </section>

  <!-- ============================ STATS STRIP ============================ -->
  <section class="bg-navy-dark">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-14 md:py-16">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {
          stats.map((s) => (
            <div class="text-center md:text-left">
              <dt class="sr-only">{s.label}</dt>
              <dd>
                <span class="block font-display text-3xl text-cream md:text-4xl">
                  {s.value}
                </span>
                <span class="mt-2 block text-sm font-semibold uppercase tracking-[0.16em] text-brass">
                  {s.label}
                </span>
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- ============================ TESTIMONIAL ============================ -->
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-5 sm:px-8 py-20 md:py-28 text-center">
      <svg
        viewBox="0 0 24 24"
        class="mx-auto h-10 w-10 text-brass/50"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M7.5 6C5 6 3 8 3 10.5S5 15 7.5 15c0 2-1 3-3 3.5 3.5-.2 6-3 6-6.5V6H7.5Zm10 0C15 6 13 8 13 10.5S15 15 17.5 15c0 2-1 3-3 3.5 3.5-.2 6-3 6-6.5V6h-3Z"
        ></path>
      </svg>
      {
        testimonials.map((t) => (
          <figure>
            <blockquote class="mt-6 font-display text-2xl leading-snug text-navy sm:text-3xl md:text-[2.1rem] md:leading-[1.3]">
              “{t.quote}”
            </blockquote>
            <figcaption class="mt-7 text-sm font-semibold uppercase tracking-[0.16em] text-brass-deep">
              {t.name}
              <span class="font-normal normal-case tracking-normal text-muted">
                {" "}
                · {t.role}
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- ======================= MEET THE BARN CREW ======================= -->
  <section class="bg-oat">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-20 md:py-24">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
        <div class="max-w-xl">
          <p class="eyebrow eyebrow--rule">The barn crew</p>
          <h2 class="mt-4 text-3xl sm:text-4xl text-navy">
            Familiar faces around the barn
          </h2>
        </div>
        <a href={withBase("/about")} class="btn btn-outline shrink-0"> Meet everyone </a>
      </div>

      <ul class="mt-12 grid grid-cols-2 gap-8 sm:grid-cols-4">
        {
          crew.map((m) => (
            <li class="flex flex-col items-center text-center">
              <div class="aspect-square w-full max-w-[180px] overflow-hidden rounded-full ring-1 ring-brass/25 shadow-md">
                <Image
                  src={m.img}
                  alt={m.alt}
                  width={360}
                  height={360}
                  class="h-full w-full object-cover"
                  style={`object-position: ${m.position};`}
                />
              </div>
              <p class="mt-4 font-display text-lg font-semibold text-navy">
                {m.name}
              </p>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brass-deep">
                {m.role}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <CtaBand />
</Layout>
