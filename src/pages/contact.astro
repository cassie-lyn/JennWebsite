---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import { site, mapEmbed } from "../data/site";
import sideImg from "../assets/photos/sunrise-vivid.jpg";

const interests = ["Boarding", "Training", "Lessons", "Clinics", "Something else"];

const description =
  "Contact Avastar Dressage in Lincoln, RI. Call Jenn at (401) 595-2217 for boarding, training, and lesson inquiries, or send a message. Located at Lepore Farm, 545 Angell Rd.";
---

<Layout title="Contact" description={description}>
  <!-- Header -->
  <section class="bg-gradient-to-b from-oat to-cream">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 pt-14 pb-10 md:pt-20">
      <div class="max-w-2xl">
        <p class="eyebrow eyebrow--rule">Get in touch</p>
        <h1 class="mt-4 text-4xl text-navy sm:text-5xl md:text-6xl">
          Come meet us.
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-ink/80">
          The best way to get a feel for Avastar is to visit. For boarding,
          training, and lesson inquiries, a phone call is the fastest way to
          reach Jenn.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact details + form -->
  <section class="bg-cream">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 pb-20 md:pb-24">
      <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
        <!-- Details -->
        <div class="lg:col-span-5">
          <div class="rounded-2xl border border-line bg-oat/50 p-7 sm:p-8">
            <dl class="space-y-7">
              <div>
                <dt
                  class="text-xs font-semibold uppercase tracking-[0.16em] text-brass-deep"
                >
                  Call · the fastest way
                </dt>
                <dd class="mt-2">
                  <a
                    href={site.phone.href}
                    class="font-display text-3xl text-navy transition-colors hover:text-brass-deep sm:text-4xl"
                  >
                    {site.phone.display}
                  </a>
                </dd>
              </div>

              <div>
                <dt
                  class="text-xs font-semibold uppercase tracking-[0.16em] text-brass-deep"
                >
                  Email
                </dt>
                <dd class="mt-2">
                  <a
                    href={`mailto:${site.email}`}
                    class="text-lg text-ink/90 underline decoration-brass/40 underline-offset-4 transition-colors hover:text-brass-deep break-all"
                  >
                    {site.email}
                  </a>
                </dd>
              </div>

              <div>
                <dt
                  class="text-xs font-semibold uppercase tracking-[0.16em] text-brass-deep"
                >
                  Visit
                </dt>
                <dd class="mt-2 not-italic leading-relaxed text-ink/85">
                  <address class="not-italic">
                    {site.address.line1}<br />
                    {site.address.line2}<br />
                    {site.address.city}, {site.address.state} {site.address.zip}
                  </address>
                </dd>
              </div>

              <div>
                <dt
                  class="text-xs font-semibold uppercase tracking-[0.16em] text-brass-deep"
                >
                  Follow
                </dt>
                <dd class="mt-2">
                  <a
                    href={site.facebook}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-ink/90 transition-colors hover:text-brass-deep"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      class="h-5 w-5"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path
                        d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"
                      ></path>
                    </svg>
                    Avastar Dressage on Facebook
                  </a>
                </dd>
              </div>
            </dl>
          </div>

          <div class="photo-frame mt-6 aspect-[5/4] sm:aspect-[4/3] lg:aspect-[4/5]">
            <Image
              src={sideImg}
              alt="A vivid pink-and-red sunrise over Lepore Farm"
              width={880}
              class="h-full w-full object-cover"
              style="object-position: center;"
            />
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-7">
          <div class="rounded-2xl border border-line bg-cream p-7 shadow-sm sm:p-9">
            <h2 class="text-2xl text-navy sm:text-3xl">Send a message</h2>
            <p class="mt-2 text-sm text-muted">
              Fields marked <span class="text-brass-deep">*</span> are required.
            </p>

            <!--
              This form submits to Web3Forms, which emails each submission to
              the address tied to the access_key below. It works on GitHub Pages
              (no server needed).

              TO CHANGE WHO GETS THE EMAILS (e.g. Jenn or Bree): create a new
              free key at web3forms.com for their email, then replace the
              access_key value in the hidden input below. Nothing else changes.
              The key is meant to be public; spam is handled by the honeypot.
            -->
            <form id="contact-form" class="mt-7 space-y-5" novalidate>
              <input
                type="hidden"
                name="access_key"
                value="00990a4f-1ce4-466f-ba7a-32005a0afb5d"
              />
              <input
                type="hidden"
                name="from_name"
                value="Avastar Dressage Website"
              />
              <!-- Honeypot: hidden from people, tempting to bots -->
              <input
                type="checkbox"
                name="botcheck"
                class="hidden"
                style="display:none"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label
                    for="name"
                    class="block text-sm font-medium text-ink"
                  >
                    Name <span class="text-brass-deep">*</span>
                  </label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    required
                    autocomplete="name"
                    class="mt-2 w-full rounded-lg border border-line bg-cream px-4 py-3 text-ink placeholder:text-muted/70 focus:border-brass focus:outline-none"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label
                    for="email"
                    class="block text-sm font-medium text-ink"
                  >
                    Email <span class="text-brass-deep">*</span>
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    class="mt-2 w-full rounded-lg border border-line bg-cream px-4 py-3 text-ink placeholder:text-muted/70 focus:border-brass focus:outline-none"
                    placeholder="you@example.com"
                  />
                </div>
              </div>

              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label
                    for="phone"
                    class="block text-sm font-medium text-ink"
                  >
                    Phone <span class="text-muted">(optional)</span>
                  </label>
                  <input
                    id="phone"
                    name="phone"
                    type="tel"
                    autocomplete="tel"
                    class="mt-2 w-full rounded-lg border border-line bg-cream px-4 py-3 text-ink placeholder:text-muted/70 focus:border-brass focus:outline-none"
                    placeholder="(401) 555-0100"
                  />
                </div>
                <div>
                  <label
                    for="interest"
                    class="block text-sm font-medium text-ink"
                  >
                    I'm interested in <span class="text-brass-deep">*</span>
                  </label>
                  <select
                    id="interest"
                    name="interest"
                    required
                    class="mt-2 w-full rounded-lg border border-line bg-cream px-4 py-3 text-ink focus:border-brass focus:outline-none"
                  >
                    <option value="" disabled selected>Choose one…</option>
                    {interests.map((i) => <option value={i}>{i}</option>)}
                  </select>
                </div>
              </div>

              <div>
                <label
                  for="message"
                  class="block text-sm font-medium text-ink"
                >
                  Message <span class="text-brass-deep">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="mt-2 w-full rounded-lg border border-line bg-cream px-4 py-3 text-ink placeholder:text-muted/70 focus:border-brass focus:outline-none"
                  placeholder="Tell us a little about your horse and what you're looking for."
                ></textarea>
              </div>

              <div>
                <button
                  type="submit"
                  id="form-submit"
                  class="btn btn-brass w-full sm:w-auto"
                >
                  Send message
                </button>
                <p class="mt-3 text-sm text-muted">
                  We'll get your message by email. You can also just call
                  <a
                    href={site.phone.href}
                    class="font-medium text-navy underline decoration-brass/40 underline-offset-2 hover:text-brass-deep"
                    >{site.phone.display}</a
                  >.
                </p>
                <p
                  id="form-status"
                  role="status"
                  aria-live="polite"
                  hidden
                  class="mt-4 rounded-lg px-4 py-3 text-sm"
                >
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="bg-oat">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16 md:py-20">
      <div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow eyebrow--rule">Find the farm</p>
          <h2 class="mt-3 text-2xl text-navy sm:text-3xl">
            Lepore Farm, Lincoln, RI
          </h2>
        </div>
        <a
          href="https://www.google.com/maps/dir/?api=1&destination=545+Angell+Rd,+Lincoln,+RI+02865"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-semibold text-brass-deep hover:text-brass-hover"
        >
          Get directions →
        </a>
      </div>
      <div
        class="overflow-hidden rounded-2xl border border-line shadow-sm"
      >
        <iframe
          title="Map to Avastar Dressage at 545 Angell Rd, Lincoln, RI"
          src={mapEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="h-[380px] w-full md:h-[440px]"
          style="border:0;"
        ></iframe>
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Prefer to talk?"
    heading="Jenn is just a phone call away"
    body="For boarding, training, lessons, or a visit, calling is the quickest way to get an answer."
    showMessageButton={false}
  />
</Layout>

<script>
  // --- Web3Forms submission -------------------------------------------------
  // Posts the form to Web3Forms, which emails it to the address tied to the
  // access_key (hidden input in the <form>). To change the recipient, swap that
  // key. Works on static hosting like GitHub Pages.
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const statusEl = document.getElementById(
    "form-status"
  ) as HTMLParagraphElement | null;
  const submitBtn = document.getElementById(
    "form-submit"
  ) as HTMLButtonElement | null;

  function showStatus(kind: "success" | "error", msg: string) {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.hidden = false;
    statusEl.className =
      "mt-4 rounded-lg px-4 py-3 text-sm " +
      (kind === "success"
        ? "bg-navy/5 text-navy ring-1 ring-brass/30"
        : "bg-red-50 text-red-800 ring-1 ring-red-200");
  }

  const errorMsg =
    "Sorry, something went wrong sending your message. Please call (401) 595-2217 and we'll help right away.";

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    data.set(
      "subject",
      `Avastar website inquiry: ${data.get("interest") || "General"}`
    );

    const original = submitBtn?.textContent ?? "Send message";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";
    }
    if (statusEl) statusEl.hidden = true;

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { Accept: "application/json" },
        body: data,
      });
      const json = await res.json();
      if (json.success) {
        form.reset();
        showStatus(
          "success",
          "Thanks for reaching out. Your message is on its way, and we'll be in touch soon."
        );
      } else {
        showStatus("error", errorMsg);
      }
    } catch {
      showStatus("error", errorMsg);
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = original;
      }
    }
  });
</script>
